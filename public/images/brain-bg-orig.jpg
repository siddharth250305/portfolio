    <style>
        html,body {
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: monospace;
            background-color: hsl(0, 0%, 7%);
            color: hsl(190 100% 50% / 1);
            display: flex;
            flex-direction: column;
            -webkit-user-select: none;
            user-select: none;
        }

        main {
            flex: 1;
            overflow-y: auto;
            padding: 25px;
        }

        .ascii-container {
            display: flex;
            flex-wrap: wrap;
            padding: 10px 0;
            gap: 30px;
            align-items: flex-start;
            text-align: left;
        }

        .main-logo {
            font-family: 'Cascadia Code', monospace;
            font-size: 2.8px;
            line-height: 1;
            color: hsl(190 100% 50% / 1);
            text-shadow: hsl(190 100% 50% / 1) 0px 0px 1px;
            max-width: 100%;
            overflow: auto;
        }

        .ascii-404 {
            font-family: monospace;
            color: hsl(190 100% 50% / 1);
            font-size: 16px;
            padding: 0 10px;
            font-weight: bold;
            white-space: pre;
            line-height: 1.2;
        }

        .ascii-404 span {
            font-size: 17px;
        }

        footer {
            position: relative;
            bottom: 0; left: 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            font-weight: 500;
            width: 100%;
            border-top: 0.5px solid hsl(190, 100%, 50%);
            text-align: center;
        }

        .copyright-symbol {
            font-size: 20px;
            vertical-align: middle;
        }

        .command-line {
            display: flex;
            gap: 5px;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .user-input {
            outline: none;
            color: white;
            flex-grow: 1;
            -webkit-user-select: text;
            user-select: text;
        }

        .terminal-output {
            color: white;
            margin: 20px;
            font-size: 14px;
            font-weight: 300;
            -webkit-user-select: text;
            user-select: text;
        }

        .terminal-output,
        .terminal-output * {
            font-family: 'JetBrains Mono', monospace;
        }

        .terminal-output-line {
            overflow-x: auto;
            margin-bottom: 10px;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .terminal-output-line::-webkit-scrollbar {
            display: none;
        }

        .prompt {
            color: hsl(190, 100%, 50%);
            font-weight: bold;
        }

        #user-input {
            outline: none;
            display: inline-block;
            min-width: 10px;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        @media (max-width: 992px) {
            .main-logo {
                font-size: 2.3px;
            }
            .ascii-404 {
                font-size: 14px;
            }
        }

        @media (max-width: 768px) {
            main {
                padding: 15px;
            }
            .command-terminal {
                margin: 15px;
            }
            .main-logo {
                font-size: 1.8px;
            }
            .ascii-404 {
                font-size: 10px;
            }
            .ascii-404 span {
                font-size: 14px;
            }
        }

        @media (max-width: 576px) {
            main {
                padding: 10px;
            }
            .command-terminal {
                margin: 10px;
            }
            .ascii-container {
                gap: 15px;
            }
        }

        @media (max-width: 420px) {
            .main-logo {
                font-size: 1.5px;
            }
            .ascii-404 {
                font-size: 8px;
            }
            .ascii-404 span {
                font-size: 11px;
            }
        }
    </style>
</head>

