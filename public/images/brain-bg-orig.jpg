</main>

<script type="6f95c98921500bfe4397193d-text/javascript">
    let terminalOutput;

    function scrollToBottom() {
        window.scrollTo(0, document.body.scrollHeight);
    }

    function escapeHTML(str) {
        return str.replace(/[&<>"']/g, m => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
        })[m]);
    }

    function printToTerminal(text) {
        const outputDiv = document.createElement("div");
        outputDiv.className = "terminal-output-line";
        outputDiv.innerHTML = `<pre>${escapeHTML(text)}</pre>`;
        terminalOutput.appendChild(outputDiv);
        scrollToBottom();
    }

    function getCommandOutput(cmd) {
        switch (cmd.toLowerCase()) {
            case "help":
                return (
                    "Available commands:\n\n" +
                    "home              - Return to the homepage\n" +
                    "iabhinav          - Open my personal portfolio website\n" +
                    "clear             - Clear the terminal screen\n" +
                    "help              - Display this help message"
                );
            case 'home':
                window.location.href = '/';
                return null;
            case 'iabhinav':
                window.open("https://iabhinav.me", "_blank");
                return null;
            case 'date':
                printToTerminal(`${new Date().toDateString()}`);
                return null;
            case 'time':
                printToTerminal(`${new Date().toLocaleTimeString()}`);
                return null;
            case 'clear':
                terminalOutput.innerHTML = '';
                const hintLine = document.createElement("div");
                hintLine.innerHTML = `<span>Type <span class="prompt">'help'</span> to view a list of available commands.</span><br><br>`;
                terminalOutput.insertBefore(hintLine, terminalOutput.firstChild);
                return null;
            default:
                return `Command not found: ${cmd}`;
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const yearSpan = document.getElementById("currentYear");
        if (yearSpan) {
            yearSpan.textContent = new Date().getFullYear();
        }

        terminalOutput = document.querySelector(".terminal-output");

        function createInputLine() {
            const wrapper = document.createElement("div");
            wrapper.className = "command-line";

            const prompt = document.createElement("span");
            prompt.className = "prompt";
            prompt.textContent = "visitor@iabhinav.me:~$ ";

            const input = document.createElement("span");
            input.className = "user-input";
            input.contentEditable = "true";
            input.spellcheck = false;

            input.addEventListener("keydown", function handler(e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    const cmd = input.innerText.trim();

                    input.contentEditable = "false";
                    input.removeEventListener("keydown", handler);

                    const outputText = getCommandOutput(cmd);
                    if (outputText !== null) {
                        const outputDiv = document.createElement("div");
                        outputDiv.className = "terminal-output-line";
                        outputDiv.innerHTML = `<pre>${escapeHTML(outputText)}</pre>`;
                        input.parentNode.insertAdjacentElement("afterend", outputDiv);
                    }

                    terminalOutput.appendChild(createInputLine());
                    scrollToBottom();
                }
            });

            wrapper.appendChild(prompt);
            wrapper.appendChild(input);
            terminalOutput.appendChild(wrapper);
            setTimeout(() => input.focus(), 0);
            return wrapper;
        }

        createInputLine();
    });

    document.addEventListener("click", () => {
        const inputs = document.querySelectorAll(".user-input[contenteditable='true']");
        if (inputs.length > 0) {
            const lastInput = inputs[inputs.length - 1];
            lastInput.focus();
            const range = document.createRange();
            range.selectNodeContents(lastInput);
            range.collapse(false);
            const selection = window.getSelection();
            selection.removeAllRanges();
            selection.addRange(range);
        }
    });
</script>

